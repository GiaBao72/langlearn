    <page path="/blog" auth="public" description="Blog listing"/>
    <page path="/store" auth="public" description="Book store"/>
    <page path="/practice/[lessonId]" auth="public" description="5 exercise types interactive"/>
    <page path="/dashboard" auth="required" description="User dashboard - heatmap, streak"/>
    <page path="/admin" auth="admin" description="Admin panel"/>
    <page path="/admin/courses/[id]" auth="admin" description="Course edit + lesson management"/>
    <page path="/admin/lessons/[id]" auth="admin" description="Lesson edit + exercise management"/>
    <page path="/admin/blog/new" auth="admin" description="Blog editor + Word import"/>
  </pages>

