  <schema>
    <model name="User" fields="id,email,passwordHash,name,role,createdAt,updatedAt"/>
    <model name="RefreshToken" fields="id,token,userId,expiresAt,revokedAt,createdAt"/>
    <model name="Course" fields="id,title,language,level,description,published,createdAt,updatedAt"/>
    <model name="Lesson" fields="id,courseId,title,order,content,published,createdAt,updatedAt"/>
    <model name="Exercise" fields="id,lessonId,type,question,data(JSON),points,order"/>
    <model name="UserProgress" fields="id,userId,exerciseId,score,completedAt" unique="userId+exerciseId"/>
    <model name="BlogPost" fields="id,title,slug,content,excerpt,published,publishedAt,createdAt,updatedAt"/>
  </schema>

  <exercise_types>
    <type name="MULTIPLE_CHOICE" scoring="full or zero"/>
    <type name="FILL_BLANK" scoring="full or zero (case insensitive)"/>
    <type name="FLASHCARD" scoring="full or zero (self-reported)"/>
    <type name="DICTATION" scoring="partial - % words correct"/>
    <type name="SORT_WORDS" scoring="full or zero"/>
  </exercise_types>

  <apis>
    <group name="Auth">
      <endpoint method="POST" path="/api/auth/login"/>
      <endpoint method="POST" path="/api/auth/register"/>
      <endpoint method="POST" path="/api/auth/logout"/>
      <endpoint method="POST" path="/api/auth/refresh"/>
    </group>
    <group name="Public">
      <endpoint method="GET" path="/api/blog"/>
      <endpoint method="GET" path="/api/courses"/>
      <endpoint method="GET" path="/api/lessons/[id]/exercises"/>
    </group>
    <group name="Protected">
      <endpoint method="POST" path="/api/exercises/[id]/submit"/>
      <endpoint method="GET|POST" path="/api/progress"/>
    </group>
    <group name="Admin">
      <endpoint method="GET|POST" path="/api/admin/courses"/>
      <endpoint method="GET|PATCH|DELETE" path="/api/admin/courses/[id]"/>
      <endpoint method="GET|POST" path="/api/admin/courses/[id]/lessons"/>
      <endpoint method="GET|PATCH|DELETE" path="/api/admin/lessons/[id]"/>
      <endpoint method="GET|POST" path="/api/admin/lessons/[id]/exercises"/>
      <endpoint method="GET|PATCH|DELETE" path="/api/admin/exercises/[id]"/>
      <endpoint method="GET|POST|PATCH|DELETE" path="/api/admin/blog"/>
    </group>
  </apis>

  <pages>
