  <bugs_fixed>
    <bug id="1" desc="jsonwebtoken không chạy Edge Runtime" fix="Dùng jose (Web Crypto API)"/>
    <bug id="2" desc="Cookie Secure=true block trên HTTP" fix="Check NEXTAUTH_URL.startsWith('https')"/>
    <bug id="3" desc="pm2 không load .env" fix="Hardcode env trong ecosystem.config.js"/>
    <bug id="4" desc="Server component tự redirect() bypass middleware" fix="Bỏ auth guard, guest = null"/>
    <bug id="5" desc="router.push() sau login không re-render Navbar" fix="window.location.href = full reload"/>
    <bug id="6" desc="Navbar server component import trong use client tree" fix="Dùng jose, move Navbar lên server wrapper"/>
    <bug id="7" desc="MultipleChoice closure bug" fix="useRef để preserve state"/>
    <bug id="8" desc="GitHub Actions continue-on-error mask failures" fix="Remove continue-on-error"/>
    <bug id="9" desc="VPS stale build" fix="Workflow thêm npm run build trước pm2 restart"/>
  </bugs_fixed>

  <lessons_learned>
    <lesson>Next.js App Router: async server components không thể import trong 'use client' component tree</lesson>
    <lesson>Next.js App Router: router.push() là client-side nav, server components không re-render → dùng window.location.href</lesson>
    <lesson>Next.js Edge Runtime: chỉ support Web Crypto API, không support Node.js built-ins → jose thay jsonwebtoken</lesson>
    <lesson>pm2 fork mode là đủ cho Next.js; cluster mode không compatible</lesson>
    <lesson>Middleware public paths không đủ nếu server component tự gọi redirect()</lesson>
  </lessons_learned>

